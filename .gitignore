# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/

# Node
node_modules/
dist/
*.log

# Build/deps of the npm package are regenerated by scripts/prepare-plugin.mjs.
# (covered by node_modules/ and dist/ above — listed here for clarity)
web-eyes/package/dist/
web-eyes/package/node_modules/

# BUT the plugin ships its compiled dist AND prod deps committed — that's what
# makes the MCP server work on a fresh clone (Claude Code spawns `node dist/index.js`
# directly). Force them back in, overriding the node_modules/ + dist/ rules above.
!web-eyes/plugin/dist/
!web-eyes/plugin/dist/**
!web-eyes/plugin/node_modules/
!web-eyes/plugin/node_modules/**

# Local, per-machine Claude settings (permissions + absolute paths). Not shared.
.claude/settings.local.json
